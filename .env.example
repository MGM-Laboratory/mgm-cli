# mgm-cli — environment configuration example
#
# Copy what you need into your shell environment (or a .env you source). Nothing
# here is hardcoded in the binary: every value below has a documented default
# that can be overridden. CLI flags > .mgm.yaml > ~/.mgm/config > env > defaults.

# ──────────────────────────────────────────────────────────────────────────
# Megumi Code — mgm account auth (`mgm auth`, `mgm whoami`, future `mgm megumi`)
# Integrates with Keycloak at iam.labmgm.org. See the backend runbook:
# mgm-cli-backend/docs/keycloak.md (realm, CLI client, roles, redirect URIs).
# ──────────────────────────────────────────────────────────────────────────

# Keycloak realm issuer URL. OIDC endpoints (authorization/token/device) are
# discovered from "<issuer>/.well-known/openid-configuration" — never hardcoded.
MEGUMI_OIDC_ISSUER=https://iam.labmgm.org/realms/mgm

# Public CLI client id (Keycloak). Standard flow + Device grant ON, PKCE S256.
MEGUMI_OIDC_CLIENT_ID=mgm-cli

# Scopes requested at login. "offline_access" is required to receive a refresh
# token for transparent re-authentication.
MEGUMI_OIDC_SCOPES=openid profile email offline_access

# Backend broker base URL. Used by `mgm whoami` to confirm/enrich the identity
# via GET /api/v1/me (optional; whoami degrades gracefully if unreachable).
MEGUMI_BASE_URL=https://cli-api.labmgm.org

# Realm-role (or group) names that map a user to the admin / operator display
# role. Must match what the backend uses (MEGUMI_ROLE_* in the runbook). Anyone
# without these is shown as "member".
MEGUMI_ROLE_ADMIN=megumi-admin
MEGUMI_ROLE_OPERATOR=megumi-operator

# Extended-thinking effort tier for `mgm megumi`, sent to the broker as the
# x-megumi-effort header (the broker maps it to a thinking-token budget).
# One of: low | medium | high. Default medium. (A live /effort picker is Phase 3.)
MEGUMI_EFFORT=medium

# Model labels (Meji/Gumi/Miyu) are fixed product identifiers sent to the broker;
# the broker maps each label to an upstream model ID via its own env. The CLI
# never hardcodes an upstream model string.

# Public Megumi Code website, surfaced in the agent's self-identity (the model
# knows it is Megumi Code, made by MGM Laboratory / Universitas Brawijaya).
# Default https://cli.labmgm.org.
# MEGUMI_SITE_URL=https://cli.labmgm.org

# Credential store backend selection. "auto" (default) uses the OS keychain when
# usable and falls back to a 0600 AES-256-GCM encrypted file under ~/.mgm/megumi.
# Force with "keychain" or "file" (e.g. "file" on a headless server).
# MEGUMI_CRED_STORE=auto

# Override the Megumi state directory (default: ~/.mgm/megumi). Mainly for tests.
# MEGUMI_HOME=

# ──────────────────────────────────────────────────────────────────────────
# Existing namespaces (for reference — see README "Configuration")
# ──────────────────────────────────────────────────────────────────────────

# env / Infisical
# MGM_HOST_URL=https://secrets.labmgm.org
# MGM_CLIENT_ID=
# MGM_CLIENT_SECRET=
# MGM_PROJECT_ID=
# MGM_ENVIRONMENT=
# MGM_FOLDER=

# status / Gatus
# MGM_GATUS_URL=https://status.labmgm.org
# MGM_GATUS_TOKEN=

# General
# MGM_PROFILE=default
# MGM_CONFIG=
# MGM_NO_TUI=1

# ──────────────────────────────────────────────────────────────────────────
# Release / CI publish targets (GitHub Actions secrets/variables, NOT runtime
# CLI config). A tagged release publishes only the targets whose token is set;
# the core binary + deb/rpm/apk/Arch release always runs. See docs/release.md.
# ──────────────────────────────────────────────────────────────────────────
# HOMEBREW_TAP_GITHUB_TOKEN=   # push the cask to MGM-Laboratory/homebrew-mgm
# SCOOP_BUCKET_GITHUB_TOKEN=   # push the manifest to MGM-Laboratory/scoop-mgm
# NUR_GITHUB_TOKEN=            # push the Nix expr to MGM-Laboratory/nur
# AUR_KEY=                     # SSH private key for the AUR mgm-bin package
# DOCKERHUB_USERNAME=          # Docker Hub login (image publish)
# DOCKERHUB_TOKEN=             # Docker Hub token
# DOCKERHUB_IMAGE=mgmlaboratory/mgm   # image name (CI repo variable)
